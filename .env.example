GEMINI_API_KEY=coloque_sua_chave_aqui
GEMINI_MODEL=gemini-2.5-flash
PORT=3000

# Guards contra abuso (opcionais — valores default já são conservadores)
# Máximo de caracteres por campo de texto do canvas
MAX_FIELD_CHARS=3000
# Máximo de caracteres do payload inteiro (JSON.stringify)
MAX_TOTAL_CHARS=20000
# Janela do rate limit por IP (ms)
RATE_WINDOW_MS=600000
# Requisições permitidas por IP dentro da janela
RATE_MAX_PER_IP=5
# Teto global de chamadas à IA por dia (reset à meia-noite UTC)
DAILY_GLOBAL_MAX=100
# Restringe o endpoint à sua URL pública (deixe vazio em dev local)
# Ex.: https://seu-app.onrender.com
ALLOWED_ORIGIN=
